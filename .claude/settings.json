{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/task-loader.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/skill-forced.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/workflow-enforced.sh"
          }
        ]
      }
    ]
  }
}
