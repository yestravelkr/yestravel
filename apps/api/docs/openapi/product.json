{
  "openapi": "3.1.0",
  "info": {
    "title": "Product API",
    "description": "상품 관리 API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/trpc/backofficeProduct.findAll": {
      "get": {
        "summary": "상품 목록 조회",
        "description": "상품 목록을 조회합니다. ids 파라미터로 특정 ID들만 조회할 수 있습니다.",
        "tags": ["Product"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT 토큰",
            "required": true,
            "example": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "schema": { "type": "string" }
          },
          {
            "name": "input",
            "in": "query",
            "description": "tRPC input (JSON)",
            "required": false,
            "schema": { "type": "string" },
            "example": "{\"page\":1,\"limit\":30,\"ids\":[1,2,3]}"
          }
        ],
        "responses": {
          "200": {
            "description": "상품 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ProductListResponse"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trpc/backofficeProduct.findById": {
      "get": {
        "summary": "상품 상세 조회",
        "description": "특정 상품의 상세 정보를 조회합니다.",
        "tags": ["Product"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT 토큰",
            "required": true,
            "example": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "schema": { "type": "string" }
          },
          {
            "name": "input",
            "in": "query",
            "description": "tRPC input (JSON)",
            "required": true,
            "schema": { "type": "string" },
            "example": "{\"id\":1}"
          }
        ],
        "responses": {
          "200": {
            "description": "상품 상세 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "oneOf": [
                            { "$ref": "#/components/schemas/HotelProductDetail" },
                            { "$ref": "#/components/schemas/DeliveryProductDetail" },
                            { "$ref": "#/components/schemas/ETicketProductDetail" }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "상품을 찾을 수 없습니다"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ProductType": {
        "type": "string",
        "enum": ["HOTEL", "E-TICKET", "DELIVERY"],
        "description": "상품 타입"
      },
      "ProductStatus": {
        "type": "string",
        "enum": ["VISIBLE", "HIDDEN", "SOLD_OUT"],
        "description": "상품 상태"
      },
      "Brand": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "FindAllProductInput": {
        "type": "object",
        "description": "상품 목록 조회 입력",
        "properties": {
          "page": {
            "type": "integer",
            "default": 1,
            "minimum": 1,
            "description": "페이지 번호"
          },
          "limit": {
            "type": "integer",
            "default": 30,
            "minimum": 1,
            "description": "페이지당 개수"
          },
          "orderBy": {
            "type": "string",
            "default": "createdAt",
            "description": "정렬 기준 필드"
          },
          "order": {
            "type": "string",
            "enum": ["ASC", "DESC"],
            "default": "DESC",
            "description": "정렬 방향"
          },
          "type": {
            "$ref": "#/components/schemas/ProductType",
            "nullable": true,
            "description": "상품 타입 필터"
          },
          "name": {
            "type": "string",
            "nullable": true,
            "description": "상품명 검색"
          },
          "status": {
            "$ref": "#/components/schemas/ProductStatus",
            "nullable": true,
            "description": "상품 상태 필터"
          },
          "brandIds": {
            "type": "array",
            "items": { "type": "integer" },
            "nullable": true,
            "description": "브랜드 ID 목록 필터"
          },
          "ids": {
            "type": "array",
            "items": { "type": "integer" },
            "nullable": true,
            "description": "조회할 상품 ID 목록 (선택)"
          },
          "dateFilterType": {
            "type": "string",
            "enum": ["CREATED_AT", "UPDATED_AT"],
            "default": "CREATED_AT",
            "description": "날짜 필터 타입"
          },
          "startDate": {
            "type": "string",
            "nullable": true,
            "description": "시작일"
          },
          "endDate": {
            "type": "string",
            "nullable": true,
            "description": "종료일"
          }
        }
      },
      "ProductListItem": {
        "type": "object",
        "description": "상품 목록 아이템",
        "properties": {
          "id": { "type": "integer", "description": "상품 ID" },
          "type": { "$ref": "#/components/schemas/ProductType" },
          "name": { "type": "string", "description": "상품명" },
          "brand": { "$ref": "#/components/schemas/Brand" },
          "thumbnail": { "type": "string", "nullable": true, "description": "썸네일 이미지 URL" },
          "price": { "type": "integer", "description": "가격" },
          "status": { "$ref": "#/components/schemas/ProductStatus" },
          "useStock": { "type": "boolean", "description": "재고 사용 여부" },
          "useCalendar": { "type": "boolean", "description": "캘린더 사용 여부" },
          "createdAt": { "type": "string", "format": "date-time", "description": "생성일시" },
          "updatedAt": { "type": "string", "format": "date-time", "description": "수정일시" }
        }
      },
      "ProductListResponse": {
        "type": "object",
        "description": "상품 목록 응답",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductListItem" }
          },
          "total": { "type": "integer", "description": "전체 개수" },
          "page": { "type": "integer", "description": "현재 페이지" },
          "limit": { "type": "integer", "description": "페이지당 개수" },
          "totalPages": { "type": "integer", "description": "전체 페이지 수" }
        }
      },
      "HotelOption": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "priceByDate": {
            "type": "object",
            "additionalProperties": { "type": "integer" },
            "description": "날짜별 가격"
          },
          "anotherPriceByDate": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "supplyPrice": { "type": "integer" },
                "commission": { "type": "integer" }
              }
            },
            "description": "날짜별 공급가/수수료"
          }
        }
      },
      "DeliveryPolicy": {
        "type": "object",
        "properties": {
          "deliveryFeeType": { "type": "string", "enum": ["FREE", "PAID", "CONDITIONAL_FREE"] },
          "deliveryFee": { "type": "integer" },
          "freeDeliveryMinAmount": { "type": "integer" },
          "returnDeliveryFee": { "type": "integer" },
          "exchangeDeliveryFee": { "type": "integer" },
          "remoteAreaExtraFee": { "type": "integer" },
          "jejuExtraFee": { "type": "integer" },
          "isJejuRestricted": { "type": "boolean" },
          "isRemoteIslandRestricted": { "type": "boolean" }
        }
      },
      "HotelProductDetail": {
        "type": "object",
        "description": "호텔 상품 상세",
        "properties": {
          "type": { "type": "string", "const": "HOTEL" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "brandId": { "type": "integer" },
          "brandName": { "type": "string" },
          "productTemplateId": { "type": "integer", "nullable": true },
          "campaignId": { "type": "integer", "nullable": true },
          "thumbnailUrls": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "detailContent": { "type": "string" },
          "useCalendar": { "type": "boolean" },
          "useStock": { "type": "boolean" },
          "useOptions": { "type": "boolean" },
          "price": { "type": "integer" },
          "status": { "$ref": "#/components/schemas/ProductStatus" },
          "displayOrder": { "type": "integer", "nullable": true },
          "baseCapacity": { "type": "integer", "description": "기준 인원" },
          "maxCapacity": { "type": "integer", "description": "최대 인원" },
          "checkInTime": { "type": "string", "description": "체크인 시간" },
          "checkOutTime": { "type": "string", "description": "체크아웃 시간" },
          "bedTypes": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "hotelOptions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HotelOption" }
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "DeliveryProductDetail": {
        "type": "object",
        "description": "배송 상품 상세",
        "properties": {
          "type": { "type": "string", "const": "DELIVERY" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "brandId": { "type": "integer" },
          "brandName": { "type": "string" },
          "productTemplateId": { "type": "integer", "nullable": true },
          "campaignId": { "type": "integer", "nullable": true },
          "thumbnailUrls": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "detailContent": { "type": "string" },
          "useCalendar": { "type": "boolean" },
          "useStock": { "type": "boolean" },
          "useOptions": { "type": "boolean" },
          "price": { "type": "integer" },
          "status": { "$ref": "#/components/schemas/ProductStatus" },
          "displayOrder": { "type": "integer", "nullable": true },
          "delivery": { "$ref": "#/components/schemas/DeliveryPolicy" },
          "exchangeReturnInfo": { "type": "string" },
          "productInfoNotice": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ETicketProductDetail": {
        "type": "object",
        "description": "E-Ticket 상품 상세",
        "properties": {
          "type": { "type": "string", "const": "E-TICKET" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "brandId": { "type": "integer" },
          "brandName": { "type": "string" },
          "productTemplateId": { "type": "integer", "nullable": true },
          "campaignId": { "type": "integer", "nullable": true },
          "thumbnailUrls": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "detailContent": { "type": "string" },
          "useCalendar": { "type": "boolean" },
          "useStock": { "type": "boolean" },
          "useOptions": { "type": "boolean" },
          "price": { "type": "integer" },
          "status": { "$ref": "#/components/schemas/ProductStatus" },
          "displayOrder": { "type": "integer", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}