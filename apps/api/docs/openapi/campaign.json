        },
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/CampaignWithRelations" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trpc/backofficeCampaign.update": {
      "post": {
        "tags": ["Campaign"],
        "summary": "캠페인 수정",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateCampaignInput" },
              "examples": {
                "full": {
                  "summary": "전체 수정",
                  "value": {
                    "id": 1,
                    "title": "수정된 캠페인명",
                    "startAt": "2025-07-01T00:00:00.000Z",
                    "endAt": "2025-08-31T23:59:59.000Z",
                    "description": "수정된 설명",
                    "products": [
                      { "productId": 1, "status": "VISIBLE" }
                    ],
                    "influencers": [
                      {
                        "influencerId": 1,
                        "periodType": "DEFAULT",
                        "feeType": "NONE",
                        "status": "VISIBLE",
                        "products": []
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/CampaignWithRelations" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/trpc/backofficeCampaign.delete": {
      "post": {
        "tags": ["Campaign"],
        "summary": "캠페인 삭제",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "integer", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "success": { "type": "boolean" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CampaignStatus": {
        "type": "string",
        "enum": ["VISIBLE", "HIDDEN", "SOLD_OUT"],
        "description": "상태: VISIBLE(노출), HIDDEN(미노출), SOLD_OUT(품절)"
      },
      "CampaignPeriodType": {
        "type": "string",
        "enum": ["DEFAULT", "CUSTOM"],
        "description": "기간 타입: DEFAULT(캠페인 기간 사용), CUSTOM(직접 입력)"
      },
      "CampaignFeeType": {
        "type": "string",
        "enum": ["NONE", "CUSTOM"],
        "description": "진행비 타입: NONE(없음), CUSTOM(직접 입력)"
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "startAt": { "type": "string", "format": "date-time" },
          "endAt": { "type": "string", "format": "date-time" },
          "description": { "type": "string", "nullable": true },
          "thumbnail": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CampaignProductInput": {
        "type": "object",
        "required": ["productId"],
        "properties": {
          "productId": { "type": "integer", "description": "상품 ID" },
          "status": { "$ref": "#/components/schemas/CampaignStatus", "default": "VISIBLE" }
        }
      },
      "CampaignProductResponse": {
        "type": "object",
        "description": "캠페인 상품 응답 (상품 정보 포함)",
        "properties": {
          "id": { "type": "integer", "description": "상품 ID" },
          "name": { "type": "string", "description": "상품명" },
          "thumbnailUrls": {
            "type": "array",
            "items": { "type": "string" },
            "description": "상품 썸네일 URL 목록"
          },
          "brand": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            },
            "description": "브랜드 정보"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "name": { "type": "string" }
              }
            },
            "description": "카테고리 목록"
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "campaignProductId": { "type": "integer", "description": "캠페인 상품 연결 ID" },
          "status": { "$ref": "#/components/schemas/CampaignStatus" }
        }
      },
      "CampaignHotelOptionInput": {
        "type": "object",
        "required": ["hotelOptionId"],
        "properties": {
          "hotelOptionId": { "type": "integer", "description": "호텔 옵션 ID" },
          "commissionByDate": {
            "type": "object",
            "additionalProperties": { "type": "number" },
            "description": "날짜별 수수료 (예: {\"2025-07-01\": 10000})",
            "example": { "2025-07-01": 10000, "2025-07-02": 12000 }
          }
        }
      },
      "CampaignHotelOptionResponse": {
        "type": "object",
        "description": "캠페인 인플루언서 호텔 옵션 응답",
        "properties": {
          "campaignInfluencerHotelOptionId": { "type": "integer", "description": "캠페인 인플루언서 호텔 옵션 ID" },
          "hotelOptionId": { "type": "integer", "description": "호텔 옵션 ID" },
          "commissionByDate": {
            "type": "object",
            "additionalProperties": { "type": "number" },
            "description": "날짜별 수수료"
          }
        }
      },
      "CampaignInfluencerProductInput": {
        "type": "object",
        "required": ["productId"],
        "properties": {
          "productId": { "type": "integer", "description": "상품 ID" },
          "useCustomCommission": { "type": "boolean", "default": false, "description": "별도 수수료 사용 여부" },
          "hotelOptions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampaignHotelOptionInput" },
            "default": []
          }
        }
      },
      "CampaignInfluencerProductResponse": {
        "type": "object",
        "description": "캠페인 인플루언서 상품 응답",
        "properties": {
          "campaignInfluencerProductId": { "type": "integer", "description": "캠페인 인플루언서 상품 ID" },
          "productId": { "type": "integer", "description": "상품 ID" },
          "useCustomCommission": { "type": "boolean", "description": "별도 수수료 사용 여부" },
          "hotelOptions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampaignHotelOptionResponse" },
            "description": "호텔 옵션 목록"
          }
        }
      },
      "CampaignInfluencerInput": {
        "type": "object",
        "required": ["influencerId"],
        "properties": {
          "influencerId": { "type": "integer", "description": "인플루언서 ID" },
          "periodType": { "$ref": "#/components/schemas/CampaignPeriodType", "default": "DEFAULT" },
          "startAt": { "type": "string", "format": "date-time", "nullable": true, "description": "CUSTOM일 때 시작일" },
          "endAt": { "type": "string", "format": "date-time", "nullable": true, "description": "CUSTOM일 때 종료일" },
          "feeType": { "$ref": "#/components/schemas/CampaignFeeType", "default": "NONE" },
          "fee": { "type": "integer", "nullable": true, "description": "CUSTOM일 때 진행비" },
          "status": { "$ref": "#/components/schemas/CampaignStatus", "default": "VISIBLE" },
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampaignInfluencerProductInput" },
            "default": [],
            "description": "인플루언서별 상품 설정"
          }
        }
      },
      "CampaignInfluencerResponse": {
        "type": "object",
        "description": "캠페인 인플루언서 응답 (인플루언서 정보 포함)",
        "properties": {
          "campaignInfluencerId": { "type": "string", "description": "캠페인 인플루언서 ID (복합키: campaignId_influencerId)" },
          "influencerId": { "type": "integer", "description": "인플루언서 ID" },
          "name": { "type": "string", "description": "인플루언서 이름" },
          "thumbnail": { "type": "string", "nullable": true, "description": "인플루언서 썸네일 URL" },
          "periodType": { "$ref": "#/components/schemas/CampaignPeriodType" },
          "startAt": { "type": "string", "format": "date-time", "nullable": true },
          "endAt": { "type": "string", "format": "date-time", "nullable": true },
          "feeType": { "$ref": "#/components/schemas/CampaignFeeType" },
          "fee": { "type": "integer", "nullable": true },
          "status": { "$ref": "#/components/schemas/CampaignStatus" },
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampaignInfluencerProductResponse" }
          }
        }
      },
      "CreateCampaignInput": {
        "type": "object",
        "required": ["title", "startAt", "endAt"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "description": "캠페인명" },
          "startAt": { "type": "string", "format": "date-time", "description": "시작일" },
          "endAt": { "type": "string", "format": "date-time", "description": "종료일" },
          "description": { "type": "string", "nullable": true, "description": "설명" },
          "thumbnail": { "type": "string", "nullable": true, "description": "썸네일 URL" },
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampaignProductInput" },
            "default": [],
            "description": "캠페인 상품 목록"
          },
          "influencers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampaignInfluencerInput" },
            "default": [],
            "description": "캠페인 인플루언서 목록"
          }
        }
      },
      "UpdateCampaignInput": {
        "allOf": [
          { "$ref": "#/components/schemas/CreateCampaignInput" },
          {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "integer", "description": "캠페인 ID" }
            }
          }
        ]
      },
      "CampaignWithRelations": {
        "allOf": [
          { "$ref": "#/components/schemas/Campaign" },
          {
            "type": "object",
            "properties": {
              "products": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/CampaignProductResponse" }
              },
              "influencers": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/CampaignInfluencerResponse" }
              }
            }
          }
        ]
      }
    }
  }
}