{
  "name": "@yestravelkr/api-types",
  "version": "1.0.0",
  "description": "Generated API types from tRPC server",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "private": true,
  "scripts": {
    "prebuild": "node scripts/inject-definitions.js",
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@trpc/server": "11.4.3",
    "zod": "^3.25.32"
  }
}
